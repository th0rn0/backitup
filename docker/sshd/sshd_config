# backitup SSH ingest (Lane A). All clients connect as the single 'backitup'
# user with their own key; per-client confinement is enforced by the forced
# command baked into each authorized_keys entry by the app (rrsync <dir> for
# rsync clients, backitup-recv <dir> for tar.gz clients). No shell, no forwarding.
Port 2222
Protocol 2
# Host key on a persisted volume so client trust survives container restarts.
HostKey /srv/hostkeys/ssh_host_ed25519_key

PermitRootLogin no
PasswordAuthentication no
KbdInteractiveAuthentication no
PubkeyAuthentication yes
AllowUsers backitup

# The app regenerates this file atomically from the database on every change.
AuthorizedKeysFile /srv/authkeys/authorized_keys
# StrictModes checks ownership/permissions on the user's home dir and ~/.ssh.
# Our AuthorizedKeysFile is at a fixed absolute path managed entirely by the
# app container, not a home dir, so the check adds no security and breaks on
# bind-mount setups where the host directory is group-readable.
StrictModes no

AllowTcpForwarding no
AllowAgentForwarding no
X11Forwarding no
PermitTunnel no
PermitUserEnvironment no

Subsystem sftp internal-sftp
